{
  "data": [
    {
      "id": "xAxisData",
      "label": "X-Axis (Date)",
      "elements": [
        {
          "id": "xDimension",
          "label": "Date",
          "type": "DIMENSION",
          "options": { "min": 1, "max": 1 }
        }
      ]
    },
    {
      "id": "breakdownData",
      "label": "Breakdown (Resource Name)",
      "elements": [
        {
          "id": "breakdownDimension",
          "label": "Resource Name",
          "type": "DIMENSION",
          "options": { "min": 0, "max": 1 }
        }
      ]
    },
    {
      "id": "metricData",
      "label": "Y-Axis (Cost)",
      "elements": [
        {
          "id": "metricValue",
          "label": "Cost",
          "type": "METRIC",
          "options": { "min": 1, "max": 1 }
        }
      ]
    }
  ],
  "style": [
    {
      "id": "orientation",
      "label": "Orientation",
      "elements": [
        {
          "id": "chartOrientation",
          "label": "Chart Orientation",
          "type": "SELECT_SINGLE",
          "options": [
            { "label": "Vertical", "value": "vertical" },
            { "label": "Horizontal", "value": "horizontal" }
          ],
          "defaultValue": "vertical"
        }
      ]
    },
    {
      "id": "axes",
      "label": "Axes",
      "elements": [
        {
          "id": "showAxisLabels",
          "label": "Show Axis Labels",
          "type": "CHECKBOX",
          "defaultValue": true
        },
        {
          "id": "yAxisCompact",
          "label": "Compact Y-Axis (K / M / B)",
          "type": "CHECKBOX",
          "defaultValue": true
        },
        {
          "id": "axisLabelFontSize",
          "label": "Axis Label Font Size",
          "type": "FONT_SIZE",
          "defaultValue": 11
        }
      ]
    },
    {
      "id": "legend",
      "label": "Legend",
      "elements": [
        {
          "id": "showLegend",
          "label": "Show Legend",
          "type": "CHECKBOX",
          "defaultValue": true
        },
        {
          "id": "legendPosition",
          "label": "Legend Position",
          "type": "SELECT_SINGLE",
          "options": [
            { "label": "Right", "value": "right" },
            { "label": "Bottom", "value": "bottom" },
            { "label": "Top", "value": "top" }
          ],
          "defaultValue": "right"
        },
        {
          "id": "legendMaxHeight",
          "label": "Legend Max Height (px)",
          "type": "TEXTINPUT",
          "defaultValue": "300"
        }
      ]
    },
    {
      "id": "chart",
      "label": "Chart",
      "elements": [
        {
          "id": "barPadding",
          "label": "Bar Padding (0.0 - 0.5)",
          "type": "TEXTINPUT",
          "defaultValue": "0.1"
        },
        {
          "id": "currencyPrefix",
          "label": "Currency Prefix (e.g. Rp, $, €)",
          "type": "TEXTINPUT",
          "defaultValue": ""
        }
      ]
    }
  ]
}
